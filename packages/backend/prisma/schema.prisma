// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model EntityConfig {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  apiUrl  String
  apiType String   @default("REST") // "REST" or "GRAPHQL"
  fields  String   // JSON string storing field definitions
}
