// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model DataSource {
  id               Int            @id @default(autoincrement())
  name             String         @unique
  apiUrl           String
  apiType          String         @default("REST") // "REST" or "GRAPHQL"
  headers          String? // JSON string of headers
  entityConfigs    EntityConfig[]
}

model EntityConfig {
  id              Int        @id @default(autoincrement())
  name            String     @unique
  dataSourceId    Int
  dataSource      DataSource @relation(fields: [dataSourceId], references: [id])
  fields          Field[]
  presets         Preset[]
  defaultPresetId Int?
  schemaName      String?
  endpointsQueries String? // JSON string containing map of operation -> endpoint/query
  auth            String? // JSON string of { view: [], create: [], edit: [], delete: [] }
}

model Preset {
  id             Int          @id @default(autoincrement())
  name           String
  gridTemplate   String
  defaultValues  String?
  entityConfigId Int
  entityConfig   EntityConfig @relation(fields: [entityConfigId], references: [id], onDelete: Cascade)
}

model Field {
  id             Int          @id @default(autoincrement())
  name           String
  type           String // "text", "number", "checkbox", "enum", "list"
  label          String
  enumName       String?
  parentField    String?
  entityConfigId Int
  entityConfig   EntityConfig @relation(fields: [entityConfigId], references: [id], onDelete: Cascade)

  @@unique([entityConfigId, name])
}
