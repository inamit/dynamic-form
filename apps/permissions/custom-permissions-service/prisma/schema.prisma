generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SitePermission {
  id         Int      @id @default(autoincrement())
  origin     String
  entityName String
  ability    String
}

model UserPermission {
  id         Int      @id @default(autoincrement())
  userId     String
  entityName String
  ability    String
  geography  String?
  fieldValue String?
}
